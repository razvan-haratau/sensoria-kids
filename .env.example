# Copiază acest fișier în .env și completează valorile reale ÎNAINTE de deploy!
# NICIODATĂ nu comite fișierul .env în git.

# ====== ADMIN ======
# Schimbă OBLIGATORIU aceste valori înainte de lansare!
# Dacă nu sunt setate, autentificarea admin este blocată complet.
VITE_ADMIN_USER=schimba_username_admin
VITE_ADMIN_PASS=schimba_parola_lunga_si_aleatoare

# ====== SUPABASE ======
# Din dashboard-ul supabase.com > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ====== STRIPE ======
# DOAR cheia publică (pk_live_... sau pk_test_...)!
# NICIODATĂ cheia secretă (sk_...) în frontend!
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ====== GOOGLE ANALYTICS 4 ======
# Measurement ID din Google Analytics > Admin > Data Streams
# Lasă gol dacă nu folosești analytics.
VITE_GA_ID=G-XXXXXXXXXX
